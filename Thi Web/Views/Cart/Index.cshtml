    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
@model List<TechShop.Models.CartItem>
@{
    ViewData["Title"] = "Giỏ hàng";
    decimal total = ViewBag.Total;
}

<div class="container py-5" style="margin-top:70px">
    <h2 class="page-title mb-4"><i class="bi bi-cart3 me-2"></i>Giỏ hàng của bạn</h2>

    @if (!Model.Any())
    {
        <div class="empty-state py-5">
            <i class="bi bi-cart-x display-1 text-muted"></i>
            <h4 class="mt-3">Giỏ hàng trống</h4>
            <p class="text-muted">Hãy thêm sản phẩm vào giỏ hàng để tiếp tục mua sắm.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua sắm
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="cart-table">
                    <div class="cart-header">
                        <span>Sản phẩm</span>
                        <span>Đơn giá</span>
                        <span>Số lượng</span>
                        <span>Thành tiền</span>
                        <span></span>
                    </div>
                    @foreach (var item in Model)
                    {
                        <div class="cart-row">
                            <div class="cart-product">
                                <img src="@(item.ImageUrl ?? "https://via.placeholder.com/80")" alt="@item.ProductName" />
                                <span>@item.ProductName</span>
                            </div>
                            <span class="cart-price">@item.Price.ToString("N0") ₫</span>
                            <form asp-controller="Cart" asp-action="Update" method="post" class="cart-qty-form">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <div class="qty-control small">
                                    <button type="button" onclick="changeQty(this,-1)">-</button>
                                    <input type="number" name="quantity" value="@item.Quantity" min="1" max="99" onchange="this.form.submit()" />
                                    <button type="button" onclick="changeQty(this,1)">+</button>
                                </div>
                            </form>
                            <span class="cart-sub">@item.Subtotal.ToString("N0") ₫</span>
                            <form asp-controller="Cart" asp-action="Remove" method="post">
                                <input type="hidden" name="productId" value="@item.ProductId" />
                                <button type="submit" class="btn-remove" title="Xóa"><i class="bi bi-trash3"></i></button>
                            </form>
                        </div>
                    }
                </div>
                <div class="d-flex justify-content-between mt-3">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Tiếp tục mua
                    </a>
                    <form asp-controller="Cart" asp-action="Clear" method="post">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash me-2"></i>Xóa tất cả
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="order-summary">
                    <h5 class="mb-4">Tóm tắt đơn hàng</h5>
                    <div class="summary-row">
                        <span>Tạm tính (@Model.Sum(i => i.Quantity) sản phẩm)</span>
                        <span>@total.ToString("N0") ₫</span>
                    </div>
                    <div class="summary-row">
                        <span>Phí vận chuyển</span>
                        <span class="text-success">Miễn phí</span>
                    </div>
                    <hr>
                    <div class="summary-total">
                        <span>Tổng cộng</span>
                        <span>@total.ToString("N0") ₫</span>
                    </div>
                    <a asp-controller="Order" asp-action="Checkout" class="btn btn-primary w-100 mt-4 btn-lg">
                        <i class="bi bi-credit-card me-2"></i>Tiến hành thanh toán
                    </a>
                    <div class="secure-badge mt-3">
                        <i class="bi bi-lock-fill text-success"></i>
                        Thanh toán bảo mật 256-bit SSL
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function changeQty(btn, delta) {
            const form = btn.closest('form');
            const input = form.querySelector('input[name="quantity"]');
            const val = parseInt(input.value) + delta;
            if (val >= 1) { input.value = val; form.submit(); }
        }
    </script>
}
