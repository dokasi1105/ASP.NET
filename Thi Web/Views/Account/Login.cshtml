@model TechShop.Controllers.LoginViewModel
@{
    ViewData["Title"] = "Đăng nhập";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <i class="bi bi-cpu-fill brand-icon"></i>
            <h2>TechShop</h2>
            <p>Đăng nhập để tiếp tục</p>
        </div>

        <form asp-action="Login" method="post" asp-route-returnUrl="@ViewBag.ReturnUrl">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-icon-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="email@example.com" autocomplete="email" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" class="form-control" placeholder="••••••" autocomplete="current-password" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">Ghi nhớ đăng nhập</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">
                <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
            </button>
            <p class="text-center text-muted">
                Chưa có tài khoản?
                <a asp-controller="Account" asp-action="Register" class="text-primary fw-bold">Đăng ký ngay</a>
            </p>
            <div class="auth-hint mt-3">
                <small class="text-muted"><i class="bi bi-info-circle me-1"></i>Admin demo: admin@techshop.vn / Admin@123</small>
            </div>
        </form>
    </div>
</div>
