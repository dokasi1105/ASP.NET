@model TechShop.Controllers.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<div class="auth-page">
    <div class="auth-card">
        <div class="auth-header">
            <i class="bi bi-cpu-fill brand-icon"></i>
            <h2>TechShop</h2>
            <p>Tạo tài khoản mới</p>
        </div>

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>
            <div class="mb-3">
                <label asp-for="FullName" class="form-label"></label>
                <div class="input-icon-wrap">
                    <i class="bi bi-person"></i>
                    <input asp-for="FullName" class="form-control" placeholder="Nguyễn Văn A" />
                </div>
                <span asp-validation-for="FullName" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <div class="input-icon-wrap">
                    <i class="bi bi-envelope"></i>
                    <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock"></i>
                    <input asp-for="Password" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="ConfirmPassword" class="form-label"></label>
                <div class="input-icon-wrap">
                    <i class="bi bi-lock-fill"></i>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 btn-lg mb-3">
                <i class="bi bi-person-plus me-2"></i>Đăng ký tài khoản
            </button>
            <p class="text-center text-muted">
                Đã có tài khoản?
                <a asp-controller="Account" asp-action="Login" class="text-primary fw-bold">Đăng nhập</a>
            </p>
        </form>
    </div>
</div>
