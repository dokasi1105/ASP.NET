@model TechShop.Models.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}
<div class="container py-5" style="margin-top:70px; max-width:520px">
    <h3 class="text-white mb-3">Đặt lại mật khẩu</h3>

    <form asp-action="ResetPassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <input asp-for="Email" type="hidden" />
        <input asp-for="Token" type="hidden" />

        <label class="text-muted mb-2">Mật khẩu mới</label>
        <input asp-for="Password" class="form-control bg-dark text-light border-secondary" />
        <span asp-validation-for="Password" class="text-danger"></span>

        <label class="text-muted mt-3 mb-2">Xác nhận mật khẩu</label>
        <input asp-for="ConfirmPassword" class="form-control bg-dark text-light border-secondary" />
        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>

        <button class="btn btn-primary mt-3 w-100">Xác nhận</button>
    </form>
</div>
