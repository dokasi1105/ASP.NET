@model TechShop.Models.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}
<div class="container py-5" style="margin-top:70px; max-width:520px">
    <h3 class="text-white mb-3">Quên mật khẩu</h3>
    <form asp-action="ForgotPassword" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <label class="text-muted mb-2">Email</label>
        <input asp-for="Email" class="form-control bg-dark text-light border-secondary" placeholder="you@example.com" />
        <span asp-validation-for="Email" class="text-danger"></span>

        <button class="btn btn-primary mt-3 w-100">Gửi link đặt lại mật khẩu</button>
    </form>
</div>
