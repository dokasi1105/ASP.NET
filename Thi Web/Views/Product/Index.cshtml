@model List<TechShop.Models.Product>
@{
    ViewData["Title"] = "Sản phẩm";
    var categories = ViewBag.Categories as List<TechShop.Models.Category>;
}

<div class="container py-4" style="margin-top:70px">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="container py-4" style="margin-top:70px">
            <form asp-action="Index" method="get" id="filterForm">
                <div class="row g-4">
                    <div class="col-lg-3">
                        <div class="sidebar-filter p-4 rounded" style="background-color: var(--bg-dark-surface); border: 1px solid var(--bg-dark-elevated);">
                            <h5 class="filter-title mb-4 border-bottom pb-3"><i class="bi bi-funnel text-cyan me-2"></i>Bộ Lọc Tìm Kiếm</h5>

                            @if (ViewBag.SelectedCategory != null)
                            {
                                <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategory" />
                            }

                            <div class="filter-block mb-4">
                                <label class="form-label fw-bold text-light mb-3">Thương Hiệu</label>
                                <select name="brand" class="form-select bg-dark text-light border-secondary">
                                    <option value="">-- Tất cả thương hiệu --</option>
                                    @foreach (var b in ViewBag.Brands)
                                    {
                                        <option value="@b" selected="@(ViewBag.SelectedBrand == b)">@b</option>
                                    }
                                </select>
                            </div>

                            <div class="filter-block mb-4">
                                <label class="form-label fw-bold text-light mb-3">Khoảng Giá (VNĐ)</label>
                                <div class="d-flex flex-column gap-2">
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-dark text-muted border-secondary">Từ</span>
                                        <input type="number" name="minPrice" class="form-control bg-dark text-light border-secondary" placeholder="0" value="@ViewBag.MinPrice" />
                                    </div>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-dark text-muted border-secondary">Đến</span>
                                        <input type="number" name="maxPrice" class="form-control bg-dark text-light border-secondary" placeholder="Max" value="@ViewBag.MaxPrice" />
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-outline-info" style="border-color: var(--brand-cyan); color: var(--brand-cyan);">
                                    <i class="bi bi-funnel-fill me-1"></i> Áp dụng bộ lọc
                                </button>
                                <a asp-action="Index" class="btn btn-link text-muted text-decoration-none">Xóa tất cả</a>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-9">
                        <div class="d-flex justify-content-between align-items-center mb-4 p-3 rounded" style="background-color: var(--bg-dark-surface);">
                            <div class="results-count">
                                <span class="text-muted">Tìm thấy <strong class="text-white fs-5">@Model.Count</strong> sản phẩm phù hợp.</span>
                            </div>

                            <div class="d-flex align-items-center gap-2">
                                <label class="text-nowrap mb-0 text-muted fw-bold">Sắp xếp theo:</label>
                                <select name="sortOrder" class="form-select form-select-sm bg-dark text-light border-secondary w-auto shadow-none" onchange="this.form.submit()">
                                    <option value="">Sản phẩm Mới nhất</option>
                                    <option value="price_asc" selected="@(ViewBag.SortOrder == "price_asc")">Giá: Thấp đến Cao</option>
                                    <option value="price_desc" selected="@(ViewBag.SortOrder == "price_desc")">Giá: Cao đến Thấp</option>
                                    <option value="name_asc" selected="@(ViewBag.SortOrder == "name_asc")">Tên: A - Z</option>
                                </select>
                            </div>
                        </div>

                    </div>

                </div>
            </form>
        </div>
        <!-- Products -->
        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                <div>
                    <h5 class="mb-0 fw-bold">
                        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                        {
                            <span>Kết quả: "@ViewBag.Search"</span>
                        }
                        else if (ViewBag.SelectedCategory != null)
                        {

                            <span>@categories?.FirstOrDefault(c => c.Id == (int)ViewBag.SelectedCategory)?.Name</span>
                        }
                        else
                        {

                            <span>Tất cả sản phẩm</span>
                        }
                    </h5>
                    <small class="text-muted">@Model.Count sản phẩm</small>
                </div>
                <form asp-action="Index" method="get" class="d-flex gap-2">
                    @if (ViewBag.SelectedCategory != null)
                    {
                        <input type="hidden" name="categoryId" value="@ViewBag.SelectedCategory" />
                    }
                    <div class="search-box">
                        <input type="text" name="search" class="form-control search-input" placeholder="Tìm kiếm..." value="@ViewBag.Search" />
                        <button type="submit" class="search-btn"><i class="bi bi-search"></i></button>
                    </div>
                </form>
            </div>

            @if (!Model.Any())
            {
                <div class="empty-state">
                    <i class="bi bi-search display-1"></i>
                    <h4>Không tìm thấy sản phẩm</h4>
                    <a asp-action="Index" class="btn btn-primary mt-2">Xem tất cả</a>
                </div>
            }
            else
            {
                <div class="row g-4">
                    @foreach (var product in Model)
                    {
                        <div class="col-6 col-md-4">
                            <div class="product-card">
                                <div class="product-img-wrap">
                                    <img src="@(product.ImageUrl ?? "https://via.placeholder.com/300x200")"
                                         alt="@product.Name" class="product-img" loading="lazy" />
                                    <div class="product-overlay">
                                        <a asp-controller="Product" asp-action="Detail" asp-route-id="@product.Id" class="btn btn-light btn-sm">
                                            <i class="bi bi-eye me-1"></i>Chi tiết
                                        </a>
                                    </div>
                                    @if (product.Stock < 5 && product.Stock > 0)
                                    {
                                        <span class="badge-stock">Sắp hết</span>
                                    }
                                    else if (product.Stock == 0)
                                    {
                                        <span class="badge-stock" style="background:var(--danger);color:#fff">Hết hàng</span>
                                    }
                                </div>
                                <div class="product-body">
                                    <p class="product-cat">@product.Category?.Name</p>
                                    <h6 class="product-name">@product.Name</h6>
                                    <div class="product-footer">
                                        <span class="product-price">@product.Price.ToString("N0") ₫</span>
                                        @if (product.Stock > 0)
                                        {
                                            <form asp-controller="Product" asp-action="AddToCart" method="post">
                                                <input type="hidden" name="productId" value="@product.Id" />
                                                <button type="submit" class="btn-add-cart" title="Thêm vào giỏ">
                                                    <i class="bi bi-cart-plus"></i>
                                                </button>
                                            </form>
                                        }
                                        else
                                        {
                                            <button class="btn-add-cart" disabled style="opacity:.4;cursor:not-allowed">
                                                <i class="bi bi-cart-x"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

    </div>
</div>
