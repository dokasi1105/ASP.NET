@model List<TechShop.Models.ApplicationUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var userRoles = ViewBag.UserRoles as Dictionary<string, IList<string>>;
}

<div class="admin-page-header">
    <div>
        <h4><i class="bi bi-people me-2"></i>Quản lý người dùng</h4>
        <p class="text-muted mb-0">Tổng @Model.Count người dùng</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-table-wrap">
    <table class="table admin-table">
        <thead>
            <tr>
                <th>Họ tên</th>
                <th>Email</th>
                <th>Ngày tạo</th>
                <th>Quyền</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td><strong>@(user.FullName ?? "N/A")</strong></td>
                    <td>@user.Email</td>
                    <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td>
                        @if (userRoles!.ContainsKey(user.Id))
                        {
                            foreach (var role in userRoles[user.Id])
                            {
                                <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary") me-1">@role</span>
                            }
                        }
                    </td>
                    <td>
                        <a href="/Admin/AdminUser/AssignRole/@user.Id" class="btn btn-sm btn-warning me-1">
                            <i class="bi bi-key me-1"></i>Phân quyền
                        </a>
                        <form asp-controller="AdminUser" asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('Xóa người dùng này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@user.Id" />
                            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash3"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
