@model TechShop.Models.ApplicationUser
@{
    ViewData["Title"] = "Quản lý Đặc quyền Hội viên";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="edit-loyalty-container animate-up">
    <!-- Breadcrumb / Back Navigation -->
    <div class="mb-5">
        <a asp-action="Index" class="back-link">
            <i class="bi bi-chevron-left"></i>
            <span>Quay lại danh sách</span>
        </a>
    </div>

    <div class="row g-5 align-items-center">
        <!-- Visual Column -->
        <div class="col-lg-5 order-2 order-lg-1">
            <div class="card-viewer-wrap">
                <div class="viewer-header">
                    <h3 class="fw-800 text-white mb-1">Thẻ Hội Viên</h3>
                    <p class="text-muted small">Cập nhật thời gian thực</p>
                </div>
                
                <div class="loyalty-preview-card @Model.MembershipTier?.ToLower()">
                    <div class="badge-icon">
                        <i class="bi @(Model.MembershipTier == "Diamond" ? "bi-gem" : Model.MembershipTier == "Gold" ? "bi-trophy-fill" : "bi-award-fill")"></i>
                    </div>
                    <div class="badge-tier">@Model.MembershipTier</div>
                </div>

                <div class="user-identity mt-4 text-center">
                    <h4 class="fw-800 text-white mb-0">@Model.FullName</h4>
                    <span class="text-primary small fw-bold">@Model.Email</span>
                </div>
            </div>
        </div>

        <!-- Form Column -->
        <div class="col-lg-7 order-1 order-lg-2">
            <div class="premium-glass-card">
                <div class="glass-header mb-5">
                    <div class="top-meta">
                        <span class="status-dot"></span>
                        ADMINISTRATOR
                    </div>
                    <h2 class="display-6 fw-900 text-white mt-2">Cập nhật Đặc quyền</h2>
                    <p class="text-muted">Thay đổi thông tin hạng thẻ và điểm tích lũy của thành viên hệ thống.</p>
                </div>

                <form asp-action="UpdateLoyalty" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="userId" value="@Model.Id" />

                    <div class="row g-4">
                        <div class="col-md-6">
                            <div class="input-field-group">
                                <label class="field-label">Điểm Loyalty hiện có</label>
                                <div class="field-container">
                                    <i class="bi bi-lightning-charge-fill icon-pts"></i>
                                    <input type="number" name="points" class="field-input" value="@Model.LoyaltyPoints" required min="0" />
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="input-field-group">
                                <label class="field-label">Nâng cấp Hạng thẻ</label>
                                <div class="field-container">
                                    <i class="bi bi-stars icon-tier"></i>
                                    <select name="tier" class="field-input">
                                        <option value="Bronze" selected="@(Model.MembershipTier == "Bronze")">Bronze (Đồng)</option>
                                        <option value="Silver" selected="@(Model.MembershipTier == "Silver")">Silver (Bạc)</option>
                                        <option value="Gold" selected="@(Model.MembershipTier == "Gold")">Gold (Vàng)</option>
                                        <option value="Diamond" selected="@(Model.MembershipTier == "Diamond")">Diamond (Kim cương)</option>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="col-12 mt-5">
                            <button type="submit" class="btn-luxe-submit">
                                <span>Xác nhận cập nhật</span>
                                <i class="bi bi-arrow-right-short"></i>
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .edit-loyalty-container {
        padding: 40px 0;
        max-width: 1100px;
        margin: 0 auto;
    }

    /* Navigation */
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        color: var(--admin-text-muted);
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        transition: var(--admin-transition);
    }
    .back-link:hover { color: var(--admin-primary); transform: translateX(-5px); }

    /* Glass Card */
    .premium-glass-card {
        background: var(--admin-glass);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid var(--admin-border);
        border-radius: var(--admin-radius-xl);
        padding: 60px;
        box-shadow: var(--admin-shadow);
    }

    .top-meta {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        font-weight: 800;
        color: var(--admin-primary);
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        background: var(--admin-primary);
        border-radius: 50%;
        box-shadow: 0 0 10px var(--admin-primary);
    }

    /* Input Fields */
    .input-field-group { display: flex; flex-direction: column; gap: 12px; }
    .field-label {
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--admin-text-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .field-container { position: relative; }
    .field-container i {
        position: absolute;
        left: 20px;
        top: 50%;
        transform: translateY(-50%);
        font-size: 1.1rem;
        z-index: 2;
    }
    .icon-pts { color: #f59e0b; }
    .icon-tier { color: var(--admin-primary); }

    .field-input {
        width: 100%;
        background: var(--admin-input-bg);
        border: 1px solid var(--admin-border);
        border-radius: 18px;
        padding: 16px 20px 16px 55px;
        color: var(--admin-text-primary);
        font-weight: 600;
        transition: var(--admin-transition);
        outline: none;
    }
    .field-input:focus { 
        border-color: var(--admin-primary); 
        background: var(--admin-card-bg); 
        box-shadow: 0 0 0 4px var(--admin-primary-glow); 
    }

    /* Submit Button */
    .btn-luxe-submit {
        width: 100%;
        height: 70px;
        background: var(--admin-text-primary);
        color: var(--admin-bg-deep);
        border: none;
        border-radius: 20px;
        font-weight: 800;
        font-family: var(--font-body);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        transition: var(--admin-transition);
    }


    .btn-luxe-submit:hover {
        background: var(--admin-primary);
        color: #fff;
        transform: translateY(-4px);
        box-shadow: 0 20px 40px var(--admin-primary-glow);
    }
    .btn-luxe-submit i { font-size: 1.5rem; }

    .card-viewer-wrap { text-align: center; }
    .display-6 { 
        /* Using the cleaner body font as requested */
        font-family: var(--font-body); 
        letter-spacing: -0.01em;
        font-weight: 800;
    }
    
    /* Ensuring all inputs use the body font */
    input, select, button {
        font-family: var(--font-body);
    }
</style>



