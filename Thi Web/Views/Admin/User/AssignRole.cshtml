@{
    ViewData["Title"] = "Phân quyền người dùng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var user = ViewBag.User as TechShop.Models.ApplicationUser;
    var allRoles = ViewBag.AllRoles as List<Microsoft.AspNetCore.Identity.IdentityRole>;
    var userRoles = ViewBag.UserRoles as IList<string>;
}

<div class="admin-page-header">
    <div>
        <h4><i class="bi bi-key me-2"></i>Phân quyền người dùng</h4>
        <p class="text-muted mb-0">@user?.FullName — @user?.Email</p>
    </div>
    <a href="/Admin/AdminUser/Index" class="btn btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="admin-form-card" style="max-width:500px">
    <h6 class="mb-4">Quyền hiện tại của người dùng</h6>
    @foreach (var role in allRoles!)
    {
        var hasRole = userRoles!.Contains(role.Name!);
        <div class="role-toggle-item">
            <div>
                <strong>@role.Name</strong>
                @if (hasRole)
                {
                    <span class="badge bg-success ms-2">Đang có</span>
                }
            </div>
            <form asp-controller="AdminUser" asp-action="AssignRole" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="userId" value="@user!.Id" />
                <input type="hidden" name="roleName" value="@role.Name" />
                <input type="hidden" name="assign" value="@(!hasRole)" />
                <button type="submit" class="btn btn-sm @(hasRole ? "btn-danger" : "btn-success")">
                    @if (hasRole)
                    {
                        <span><i class="bi bi-x me-1"></i>Gỡ quyền</span>
                    }
                    else
                    {

                        <span><i class="bi bi-plus me-1"></i>Gán quyền</span>
                    }
                </button>
            </form>
        </div>
    }
</div>
