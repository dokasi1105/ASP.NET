@model List<TechShop.Models.Category>
@{
    ViewData["Title"] = "Quản lý danh mục";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h4><i class="bi bi-tags me-2"></i>Quản lý danh mục</h4>
        <p class="text-muted mb-0">@Model.Count danh mục</p>
    </div>
    <a href="/Admin/AdminCategory/Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Thêm danh mục
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-table-wrap">
    <table class="table admin-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Tên danh mục</th>
                <th>Mô tả</th>
                <th>Số sản phẩm</th>
                <th>Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var cat in Model)
            {
                <tr>
                    <td>@cat.Id</td>
                    <td><strong>@cat.Name</strong></td>
                    <td class="text-muted">@cat.Description</td>
                    <td><span class="badge bg-primary">@cat.Products.Count</span></td>
                    <td>
                        <a href="/Admin/AdminCategory/Edit/@cat.Id" class="btn btn-sm btn-warning me-1">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form asp-controller="AdminCategory" asp-action="Delete" method="post" class="d-inline"
                              onsubmit="return confirm('Xóa danh mục này?')">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@cat.Id" />
                            <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash3"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
