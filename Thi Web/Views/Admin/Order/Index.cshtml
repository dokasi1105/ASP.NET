@model List<TechShop.Models.Order>
@{
    ViewData["Title"] = "Quản lý đơn hàng";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="admin-page-header">
    <div>
        <h4><i class="bi bi-receipt me-2"></i>Quản lý đơn hàng</h4>
        <p class="text-muted mb-0">Tổng @Model.Count đơn hàng</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="admin-table-wrap">
    <table class="table admin-table">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Khách hàng</th>
                <th>Ngày đặt</th>
                <th>Tổng tiền</th>
                <th>Trạng thái</th>
                <th>Chi tiết</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var order in Model)
            {
                <tr>
                    <td><strong>#@order.Id.ToString("D6")</strong></td>
                    <td>@(order.User?.FullName ?? order.User?.Email ?? "N/A")</td>
                    <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-primary fw-bold">@order.TotalAmount.ToString("N0") ₫</td>
                    <td>
                        @{
                            var cls = order.Status switch { "Completed" => "bg-success", "Cancelled" => "bg-danger", "Processing" => "bg-info", _ => "bg-warning" };
                        }
                        <span class="badge @cls">@order.Status</span>
                    </td>
                    <td>
                        <a href="/Admin/AdminOrder/Detail/@order.Id" class="btn btn-sm btn-primary">
                            <i class="bi bi-eye me-1"></i>Xem
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
