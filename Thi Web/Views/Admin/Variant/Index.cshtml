@model List<TechShop.Models.ProductVariantGroup>
@{
    Layout = "~/Views/Admin/_AdminLayout.cshtml";
    ViewData["Title"] = "Biến thể sản phẩm";
}

<div class="admin-page-header">
    <div>
        <h4 class="text-primary fw-bold">
            <i class="bi bi-diagram-3 me-2"></i>Biến thể theo danh mục
        </h4>
        <p class="text-muted mb-0 small">
            Quản lý nhóm biến thể và các giá trị biến thể theo từng danh mục sản phẩm.
        </p>
    </div>

    <a asp-action="Create" class="btn btn-primary shadow-sm px-4">
        <i class="bi bi-plus-lg me-2"></i>Thiết lập biến thể
    </a>
</div>

<div class="admin-table-wrap shadow-sm">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Danh mục</th>
                    <th>Nhóm biến thể</th>
                    <th>Giá trị</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    @foreach (var g in Model)
                    {
                        <tr>
                            <td>
                                <span class="fw-semibold">@g.Category?.Name</span>
                            </td>
                            <td>
                                <span class="admin-badge info">@g.Name</span>
                            </td>
                            <td>
                                @if (g.Options != null && g.Options.Any())
                                {
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var option in g.Options.OrderBy(x => x.SortOrder))
                                        {
                                            <span class="admin-badge warning shadow-none">@option.Value</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <span class="text-muted">Chưa có giá trị</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3">
                            <div class="empty-state py-5">
                                <i class="bi bi-inboxes fs-1 d-block mb-3"></i>
                                <h4>Chưa có bộ biến thể nào</h4>
                                <p class="mb-0">Hãy tạo bộ biến thể đầu tiên cho danh mục sản phẩm.</p>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


