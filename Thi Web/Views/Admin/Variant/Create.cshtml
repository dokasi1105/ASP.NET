@model TechShop.Models.ProductVariant
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm biến thể";
    var products = ViewBag.Products as List<TechShop.Models.Product>;
    var options = ViewBag.Options as List<TechShop.Models.ProductVariantOption>;
}

<div class="container-fluid py-4">
    <h2 class="mb-4">Thêm biến thể</h2>

    <form asp-action="Create" method="post" class="card shadow-sm">
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Sản phẩm</label>
                <select asp-for="ProductId" class="form-select">
                    <option value="">-- Chọn sản phẩm --</option>
                    @foreach (var p in products ?? new())
                    {
                        <option value="@p.Id">@p.Name</option>
                    }
                </select>
            </div>

            <div class="mb-3">
                <label asp-for="Sku" class="form-label"></label>
                <input asp-for="Sku" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="Stock" class="form-label"></label>
                <input asp-for="Stock" class="form-control" />
            </div>

            <div class="mb-3">
                <label class="form-label">Thuộc tính biến thể</label>
                <div class="row">
                    @foreach (var o in options ?? new())
                    {
                        <div class="col-md-4 mb-2">
                            <label class="form-check">
                                <input type="checkbox" name="selectedOptionIds" value="@o.Id" class="form-check-input" />
                                <span class="form-check-label">
                                    @o.ProductVariantGroup?.Name: @o.Value
                                </span>
                            </label>
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Lưu</button>
        </div>
    </form>
</div>