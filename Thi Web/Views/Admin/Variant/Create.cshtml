@model TechShop.ViewModels.Admin.AdminVariantCatalogViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thiết lập biến thể";
    var categories = ViewBag.Categories as List<TechShop.Models.Category> ?? new();
}

<div class="admin-page-header">
    <div>
        <h4 class="text-primary fw-bold">
            <i class="bi bi-sliders me-2"></i>Thiết lập bộ biến thể
        </h4>
        <p class="text-muted mb-0 small">
            Tạo nhanh các nhóm biến thể cho từng danh mục như màu sắc, dung lượng, nâng cấp.
        </p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Quay lại danh sách
    </a>
</div>

<form asp-action="Create" method="post" class="admin-form-card shadow-sm">
    @Html.AntiForgeryToken()

    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

    <div class="row g-4">
        <div class="col-lg-4">
            <label asp-for="CategoryId" class="form-label fw-bold"></label>
            <select asp-for="CategoryId" class="form-select">
                <option value="">-- Chọn danh mục --</option>
                @foreach (var c in categories)
                {
                    <option value="@c.Id">@c.Name</option>
                }
            </select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>

        <div class="col-lg-8">
            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Colors" class="form-label fw-bold"></label>
                    <input asp-for="Colors" class="form-control" placeholder="Đen/Trắng/Xanh/Đỏ" />
                    <div class="form-text">Nhập các giá trị cách nhau bằng dấu /</div>
                    <span asp-validation-for="Colors" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Capacities" class="form-label fw-bold"></label>
                    <input asp-for="Capacities" class="form-control" placeholder="256GB/512GB/1TB/2TB" />
                    <div class="form-text">Nhập các giá trị cách nhau bằng dấu /</div>
                    <span asp-validation-for="Capacities" class="text-danger small"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Upgrades" class="form-label fw-bold"></label>
                    <input asp-for="Upgrades" class="form-control" placeholder="Standard/Plus/Pro/Pro Max" />
                    <div class="form-text">Nhập các giá trị cách nhau bằng dấu /</div>
                    <span asp-validation-for="Upgrades" class="text-danger small"></span>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a asp-action="Index" class="btn btn-outline-secondary">Hủy</a>
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-check2-circle me-2"></i>Lưu bộ biến thể
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}


