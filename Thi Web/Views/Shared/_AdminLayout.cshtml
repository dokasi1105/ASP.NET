@{
    var path = Context.Request.Path.Value ?? string.Empty;

    bool IsActive(params string[] prefixes)
    {
        foreach (var prefix in prefixes)
        {
            if (!string.IsNullOrWhiteSpace(prefix) &&
                path.StartsWith(prefix, StringComparison.OrdinalIgnoreCase))
            {
                return true;
            }
        }
        return false;
    }

    var isAdmin = User.IsInRole("Admin");
    var isStaff = User.IsInRole("Staff") || User.IsInRole("Employee") || User.IsInRole("Nhân viên");
    var displayName = User.Identity?.Name?.Split('@')[0] ?? "User";
    var roleLabel = isAdmin ? "Admin" : isStaff ? "Staff" : "User";
    var roleBadgeClass = isAdmin ? "bg-danger" : isStaff ? "bg-warning text-dark" : "bg-secondary";
    var ctrlPrefix = isAdmin ? "Admin" : "Staff";
}
<script>
    (function () {
        const key = "techshop-theme";
        const saved = localStorage.getItem(key);
        const theme = (saved === "dark" || saved === "light") ? saved : "light";
        document.documentElement.setAttribute("data-theme", theme);
    })();
</script>
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TechShop Admin</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="admin-body">
    <div class="admin-layout">
        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-brand">
                <i class="bi bi-cpu-fill"></i>
                <div>
                    <span>TechShop</span>
                    <small>Admin Panel</small>
                </div>
            </div>

            <nav class="sidebar-nav">
                @if (isAdmin || isStaff)
                {
                    <div class="nav-section-label">HỆ THỐNG</div>
                    <a asp-controller="@(ctrlPrefix + "Dashboard")" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("Dashboard") ? "active" : "")">
                        <i class="bi bi-speedometer2"></i><span>Tổng quan</span>
                    </a>

                    <div class="nav-section-label">CỬA HÀNG</div>
                    <a asp-controller="@(ctrlPrefix + "Product")" asp-action="Index"
                       class="sidebar-link @(IsActive("/" + ctrlPrefix + "Product", "/Admin/AdminProduct", "/Staff/StaffProduct") ? "active" : "")">
                        <i class="bi bi-box"></i><span>Sản phẩm</span>
                    </a>
                    <a asp-controller="@(ctrlPrefix + "Category")" asp-action="Index"
                       class="sidebar-link @(IsActive("/" + ctrlPrefix + "Category", "/Admin/AdminCategory", "/Staff/StaffCategory") ? "active" : "")">
                        <i class="bi bi-tags"></i><span>Danh mục</span>
                    </a>
                    <a asp-controller="@(ctrlPrefix + "Variant")" asp-action="Index"
                       class="sidebar-link @(Context.Request.Path.Value != null && Context.Request.Path.Value.Contains("Variant") ? "active" : "")">
                        <i class="bi bi-layers"></i><span>Biến thể</span>
                    </a>

                    <div class="nav-section-label">NGHIỆP VỤ</div>
                    <a asp-controller="@(ctrlPrefix + "Order")" asp-action="Index"
                       class="sidebar-link @(IsActive("/" + ctrlPrefix + "Order", "/Admin/AdminOrder", "/Staff/StaffOrder") ? "active" : "")">
                        <i class="bi bi-receipt"></i><span>Đơn hàng</span>
                    </a>
                    <a asp-controller="@(ctrlPrefix + "Service")" asp-action="Index"
                       class="sidebar-link @(IsActive("/" + ctrlPrefix + "Service", "/Admin/AdminService", "/Staff/StaffService") ? "active" : "")">
                        <i class="bi bi-wrench-adjustable"></i><span>Dịch vụ</span>
                    </a>
                    <a asp-controller="@(ctrlPrefix + "Coupon")" asp-action="Index"
                       class="sidebar-link @(IsActive("/" + ctrlPrefix + "Coupon", "/Admin/AdminCoupon", "/Staff/StaffCoupon") ? "active" : "")">
                        <i class="bi bi-ticket-perforated"></i><span>Mã giảm giá</span>
                    </a>

                    <div class="nav-section-label">TÀI KHOẢN</div>
                    <a asp-controller="@(ctrlPrefix + "Support")" asp-action="Index"
                       class="sidebar-link @(IsActive("/" + ctrlPrefix + "Support", "/Admin/AdminSupport", "/Staff/StaffSupport") ? "active" : "")">
                        <i class="bi bi-chat-dots"></i><span>Hỗ trợ chat</span>
                    </a>

                    @if (isAdmin)
                    {
                        <a asp-controller="AdminUser" asp-action="Index"
                           class="sidebar-link @(IsActive("/AdminUser", "/Admin/AdminUser") ? "active" : "")">
                            <i class="bi bi-people"></i><span>Người dùng</span>
                        </a>

                        <a asp-controller="AdminRole" asp-action="Index"
                           class="sidebar-link @(IsActive("/AdminRole", "/Admin/AdminRole") ? "active" : "")">
                            <i class="bi bi-shield-lock"></i><span>Phân quyền</span>
                        </a>
                    }
                }

                <div class="nav-section-label">ĐIỀU HƯỚNG</div>

                <a asp-controller="Home" asp-action="Index" class="sidebar-link">
                    <i class="bi bi-shop"></i><span>Về trang chủ</span>
                </a>

                <form asp-controller="Account" asp-action="Logout" method="post" class="mt-1">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="sidebar-link w-100 border-0 bg-transparent text-start text-danger">
                        <i class="bi bi-box-arrow-right"></i><span>Đăng xuất</span>
                    </button>
                </form>
            </nav>
        </aside>

        <!-- Main -->
        <div class="admin-main" id="adminMain">
            <header class="admin-topbar">
                <button class="sidebar-toggle" type="button" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>

                <div class="topbar-title">@ViewData["Title"]</div>

                <div class="topbar-user">
                    <i class="bi bi-person-circle me-2"></i>
                    <span>@displayName</span>
                    <span class="badge @roleBadgeClass ms-2">@roleLabel</span>
                </div>
                <button type="button"
                        class="theme-toggle-btn admin-theme-btn"
                        id="themeToggleBtn"
                        data-theme-toggle
                        aria-label="Chuyển giao diện sáng tối"
                        title="Chế độ Sáng/Tối">
                    <i class="bi bi-moon-stars-fill" id="themeToggleIcon" data-theme-toggle-icon></i>
                </button>

            </header>

            <div class="admin-content">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @if (TempData["Warning"] != null)
                {
                    <div class="alert alert-warning alert-dismissible fade show mb-3" role="alert">
                        <i class="bi bi-exclamation-circle me-2"></i>@TempData["Warning"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }

                @RenderBody()
            </div>
        </div>
    </div>

    <script>
        function toggleSidebar() {
            const sidebar = document.getElementById('adminSidebar');
            const main = document.getElementById('adminMain');

            if (!sidebar || !main) return;

            if (window.innerWidth <= 992) {
                sidebar.classList.toggle('mobile-open');
            } else {
                sidebar.classList.toggle('collapsed');
                main.style.marginLeft = sidebar.classList.contains('collapsed') ? '60px' : '240px';
            }
        }

        window.addEventListener('resize', function () {
            const sidebar = document.getElementById('adminSidebar');
            const main = document.getElementById('adminMain');

            if (!sidebar || !main) return;

            if (window.innerWidth > 992) {
                sidebar.classList.remove('mobile-open');
                main.style.marginLeft = sidebar.classList.contains('collapsed') ? '60px' : '240px';
            } else {
                main.style.marginLeft = '';
            }
        });

        setTimeout(function () {
            const alerts = document.querySelectorAll('.alert');
            alerts.forEach(function (a) {
                const bsAlert = bootstrap.Alert.getOrCreateInstance(a);
                bsAlert.close();
            });
        }, 4000);
    </script>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>