@model List<TechShop.Models.Order>
@{
    ViewData["Title"] = "Đơn hàng của tôi";
}

<div class="container py-5" style="margin-top:70px">
    <h2 class="page-title mb-4"><i class="bi bi-clock-history me-2"></i>Đơn hàng của tôi</h2>

    @if (!Model.Any())
    {
        <div class="empty-state py-5">
            <i class="bi bi-bag-x display-1 text-muted"></i>
            <h4 class="mt-3">Chưa có đơn hàng</h4>
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary mt-2">Mua sắm ngay</a>
        </div>
    }
    else
    {
        <div class="admin-table-wrap">
            <table class="table admin-table">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var order in Model)
                    {
                        <tr>
                            <td><strong>#@order.Id.ToString("D6")</strong></td>
                            <td>@order.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-primary fw-bold">@order.TotalAmount.ToString("N0") ₫</td>
                            <td>
                                @{
                                    var cls = order.Status switch { "Completed" => "bg-success", "Cancelled" => "bg-danger", "Processing" => "bg-info", _ => "bg-warning" };
                                }
                                <span class="badge @cls">@order.Status</span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
