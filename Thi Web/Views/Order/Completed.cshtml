@model TechShop.Models.Order
@{
    ViewData["Title"] = "Đặt hàng thành công";

    var paymentMethod = ViewBag.PaymentMethod as string ?? "cod";

    string qrUrl = "";
    if (paymentMethod == "bank")
    {
        // THÔNG TIN SACOMBANK CHUẨN CỦA BẠN
        string bankId = "STB"; 
        string accountNo = "0327469105";
        string accountName = "NGUYEN VIET ANH";
        
        string amount = Model!.TotalAmount.ToString("0");
        string content = $"Thanh toan don hang {Model.Id}";

        // Mã hóa URL để tránh lỗi ký tự tiếng Việt hoặc dấu cách
        string encodedContent = System.Net.WebUtility.UrlEncode(content);
        string encodedAccountName = System.Net.WebUtility.UrlEncode(accountName);

        // Tạo Link Ảnh QR Tiêu chuẩn (Gồm cả số tiền và nội dung)
        qrUrl = $"https://img.vietqr.io/image/{bankId}-{accountNo}-compact.png?amount={amount}&addInfo={encodedContent}&accountName={encodedAccountName}";
    }
}

<style>
    .order-success-page {
        background: var(--bg-dark);
        min-height: 100vh;
        color: var(--text-primary);
    }

    .success-wrap {
        animation: fadeInUp 0.8s ease;
    }

    .success-icon {
        width: 120px;
        height: 120px;
        margin: auto;
        border-radius: 50%;
        background: radial-gradient(circle at 30% 30%, #22c55e, #16a34a);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 0 30px rgba(34,197,94,0.5);
    }

    .order-info-card {
        background: var(--bg-card);
        backdrop-filter: blur(12px);
        border: 1px solid var(--border);
        color: var(--text-primary);
        padding: 30px;
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    .text-gradient {
        background: linear-gradient(90deg, #22c55e, #06b6d4);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .btn-primary {
        background: linear-gradient(135deg, #4f46e5, #06b6d4);
        border: none;
        border-radius: 10px;
        padding: 12px 20px;
        font-weight: 600;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79,70,229,0.4);
        }

    .qr-box {
        background: #fff;
        padding: 20px;
        border-radius: 12px;
    }

    @@keyframes fadeInUp {
        from

    {
        opacity: 0;
        transform: translateY(30px);
    }

    to {
        opacity: 1;
        transform: translateY(0);
    }

    }

    .qr-payment-box {
        background: var(--bg-card);
        padding: 25px;
        border-radius: 16px;
        text-align: center;
        max-width: 420px;
        margin: 30px auto;
        box-shadow: var(--shadow-lg);
        border: 1px solid var(--border);
    }

        .qr-payment-box img {
            display: block;
            margin: 15px auto;
            max-width: 260px;
        }

    .qr-title {
        font-size: 22px;
        font-weight: bold;
        color: #dc3545;
    }

    .qr-slogan {
        color: var(--text-secondary);
        font-size: 14px;
    }

    .qr-bank-info {
        background: var(--bg-dark-2);
        color: var(--text-primary);
        padding: 15px;
        border-radius: 12px;
        font-size: 14px;
        border: 1px solid var(--border);
        text-align: left;
    }

    .btn-pay-app {
        background: linear-gradient(135deg, #004a92, #0072bc); /* Sacombank Blue */
        color: #fff !important;
        border: none;
        padding: 12px 20px;
        border-radius: 10px;
        font-weight: 600;
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        text-decoration: none;
        transition: transform 0.2s;
    }

    .btn-pay-app:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(0,74,146,0.3);
    }
</style>

<div class="order-success-page">
    <div class="container py-5" style="margin-top:70px">
        <div class="success-wrap text-center">

            <div class="success-icon">
                <i class="bi bi-bag-check-fill text-white" style="font-size: 4rem;"></i>
            </div>

            <h2 class="mt-4">Đặt hàng thành công!</h2>
            <p class="lead text-primary opacity-75">
                Cảm ơn bạn đã mua hàng tại TechShop.
            </p>

            @if (paymentMethod == "bank")
            {
                <div class="qr-payment-box">
                    <div class="qr-title">
                        Thanh toán chuyển khoản
                    </div>

                    <div class="qr-slogan mb-2">
                        Quét mã QR để thanh toán nhanh chóng
                    </div>

                     <!-- Hiển thị Ảnh QR chuẩn -->
                    <img src="@qrUrl" alt="QR Thanh toán" style="max-width:300px; display:block; margin: 15px auto; border-radius: 10px; padding: 10px; background: #fff;" />

                    <div class="qr-bank-info mt-3">
                        <div class="mb-1"><strong>Ngân hàng:</strong> Sacombank (STB)</div>
                        <div class="mb-1"><strong>Chủ tài khoản:</strong> NGUYEN VIET ANH</div>
                        <div class="mb-1"><strong>Số tài khoản:</strong> 0327469105</div>
                        <div><strong>Nội dung:</strong> Thanh toan don hang @Model.Id</div>
                    </div>

                    <a href="@qrUrl" target="_blank" class="btn-pay-app mt-3">
                        <i class="bi bi-phone"></i>
                        Nhấn để Tải ảnh / Mở link QR
                    </a>

                    <div class="alert alert-warning mt-3 small">
                        <i class="bi bi-exclamation-triangle-fill me-1"></i>
                        Vui lòng chuyển khoản đúng số tiền và nội dung để hệ thống tự động xác nhận.
                        <br />
                        Đơn hàng sẽ tự động hủy sau:
                        <strong id="countdown" class="text-danger">10:00</strong>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-success mt-4 text-center">
                    <h5>Thanh toán khi nhận hàng (COD)</h5>
                    <p>Vui lòng chuẩn bị tiền khi nhận hàng.</p>
                    <p>Cảm ơn bạn đã mua sắm tại <strong>TechShop</strong>.</p>
                </div>
            }
          

            <div class="order-info-card mt-4 mx-auto" style="max-width: 800px;">
                <div class="row text-start">
                    <div class="col-md-6">
                        <p><strong>Mã đơn hàng:</strong> #@Model.Id.ToString("D6")</p>
                        <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                        <p><strong>Trạng thái:</strong> @Model.Status</p>
                    </div>
                    <div class="col-md-6">
                        <p><strong>Người nhận:</strong> @Model.FullName</p>
                        <p><strong>Địa chỉ:</strong> @Model.Address, @Model.City</p>
                        <p>
                            <strong>Tổng tiền:</strong>
                            <span class="text-gradient fw-bold">
                                @Model.TotalAmount.ToString("N0") ₫
                            </span>
                        </p>
                    </div>
                </div>

                <hr />
                <h6>Chi tiết sản phẩm</h6>

                @foreach (var od in Model.OrderDetails)
                {
                    <div class="d-flex justify-content-between mb-2">
                        <span>@od.Product?.Name x @od.Quantity</span>
                        <span>@((od.UnitPrice * od.Quantity).ToString("N0")) ₫</span>
                    </div>
                }

                <hr />
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <span>Tổng cộng</span>
                    <span class="text-gradient">@Model.TotalAmount.ToString("N0") ₫</span>
                </div>
            </div>

            <div class="mt-4 d-flex gap-3 justify-content-center">
                <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg">
                    Về trang chủ
                </a>
                <a asp-controller="Order" asp-action="MyOrders" class="btn btn-outline-secondary btn-lg">
                    Xem đơn hàng
                </a>
            </div>

        </div>
    </div>
</div>

    <script>
        // Đếm ngược thời gian thanh toán
        var countDownDate = new Date("@Model.OrderDate.ToString("yyyy-MM-ddTHH:mm:ss")");
        countDownDate.setMinutes(countDownDate.getMinutes() + 10);

        var x = setInterval(function() {
            var now = new Date().getTime();
            var distance = countDownDate.getTime() - now;

            var minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
            var seconds = Math.floor((distance % (1000 * 60)) / 1000);

            document.getElementById("countdown").innerHTML =
                (minutes < 10 ? "0" + minutes : minutes) + ":" +
                (seconds < 10 ? "0" + seconds : seconds);

            if (distance < 0) {
                clearInterval(x);
                document.getElementById("countdown").innerHTML = "ĐÃ HẾT HẠN";
                alert("Đơn hàng đã quá hạn thanh toán!");
                window.location.href = '/Order/MyOrders';
            }
        }, 1000);
    </script>
}